MONGO_URI=mongodb://localhost:27017
MONGO_DB=jupiterworldcup
MONGO_COLLECTION=wallets

SOLANA_RPC=https://api.mainnet-beta.solana.com

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Referral code to apply to each wallet (leave empty to skip referral step)
REFERRAL_CODE=

MIN_SOL_BALANCE=0.001

JUP_API_BASE=https://prediction-market-api.jup.ag/api/v1
REQUEST_TIMEOUT=30

# data/ file names (relative to data/ dir)
SEEDS_FILE=seeds.txt
PRIVATE_KEYS_FILE=privatekeys.txt
PROXIES_FILE=proxies.txt

# Max parallel wallets (only active when proxies.txt is non-empty)
MAX_WORKERS=3
